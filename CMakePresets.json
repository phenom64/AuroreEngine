{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DREAMS_BUILD_EXAMPLES": "OFF",
        "DREAMS_FIND_PACKAGES": "ON"
      }
    },
    {
      "name": "dev",
      "displayName": "Developer Debug",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "DREAMS_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "windows-vcpkg",
      "displayName": "Windows vcpkg Release",
      "inherits": "default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "binaryDir": "${sourceDir}/build/windows-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-vcpkg-dev",
      "displayName": "Windows vcpkg Debug",
      "inherits": "windows-vcpkg",
      "binaryDir": "${sourceDir}/build/windows-vcpkg-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DREAMS_BUILD_EXAMPLES": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "windows-vcpkg",
      "configurePreset": "windows-vcpkg"
    },
    {
      "name": "windows-vcpkg-dev",
      "configurePreset": "windows-vcpkg-dev"
    }
  ]
}
