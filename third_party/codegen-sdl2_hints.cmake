if(NOT DEFINED INPUT)
  message(FATAL_ERROR "INPUT is required")
endif()
if(NOT DEFINED OUTPUT)
  message(FATAL_ERROR "OUTPUT is required")
endif()
if(NOT EXISTS "${INPUT}")
  message(FATAL_ERROR "SDL hints header not found: ${INPUT}")
endif()

file(READ "${INPUT}" _sdl_hints)
string(REGEX MATCHALL "#define[ \t]+SDL_HINT_[A-Za-z0-9_]+[ \t]+\"[^\"]*\"" _hint_lines "${_sdl_hints}")

set(_generated "")
foreach(_line IN LISTS _hint_lines)
  string(REGEX REPLACE "^#define[ \t]+(SDL_HINT_[A-Za-z0-9_]+).*" "\\1" _hint_name "${_line}")
  if(_hint_name STREQUAL "SDL_HINT")
    continue()
  endif()
  string(REGEX REPLACE "^SDL_HINT_" "" _constant_name "${_hint_name}")
  string(TOLOWER "${_constant_name}" _constant_name)
  string(APPEND _generated "constexpr auto ${_constant_name} = ${_hint_name};\n")
endforeach()

get_filename_component(_output_dir "${OUTPUT}" DIRECTORY)
file(MAKE_DIRECTORY "${_output_dir}")
file(WRITE "${OUTPUT}" "${_generated}")
